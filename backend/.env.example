# ─────────────────────────────────────────────────────────────────────────────
# Phishara — Backend Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Database (defaults to SQLite — no setup needed for local dev)
DATABASE_URL=sqlite:///./phishara.db
# For MySQL: mysql+pymysql://user:password@localhost:3306/phishara

# ─────────────────────────────────────────────────────────────────────────────
# THREAT INTELLIGENCE API KEYS
# Without these, detection relies on heuristics only and WILL miss known malware.
# Both are FREE to obtain.
# ─────────────────────────────────────────────────────────────────────────────

# VirusTotal — checks URL against 70+ antivirus engines
# Get your free key at: https://www.virustotal.com/gui/my-apikey
# Free tier: 4 requests/minute, 500/day
VIRUSTOTAL_API_KEY=

# Google Safe Browsing — Google's own malware & phishing database
# Get your free key at: https://console.cloud.google.com
#   → Enable "Safe Browsing API" → Create credentials → API Key
# Free tier: 10,000 requests/day
GOOGLE_SAFE_BROWSING_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# AI — Groq (free, no download, no storage needed)
# Get your free key at: https://console.groq.com → API Keys
# ─────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
CORS_ORIGINS=http://localhost:3000
